{
  "source": {
    "include": ["./js"],
    "includePattern": ".+\\.js$",
    "excludePattern": "(node_modules|docs)"
  },
  "opts": {
    "destination": "./docs/api",
    "recurse": true,
    "encoding": "utf8"
  },
  "plugins": [
    "plugins/markdown"
  ],
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true
  }
}